{
  "name": "@0xkobold/pi-ollama",
  "version": "0.3.1",
  "description": "Ollama extension for pi-coding-agent. Unified local + cloud Ollama support with model management",
  "keywords": [
    "pi-package",
    "ollama",
    "llm",
    "local-ai"
  ],
  "author": "0xKobold",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./shared": {
      "import": "./dist/shared.js",
      "types": "./dist/shared.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "image": "https://ollama.com/public/ollama.png"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.65.2",
    "@sinclair/typebox": ">=0.32.0",
    "ollama": "^0.6.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xKobold/pi-ollama"
  },
  "bugs": {
    "url": "https://github.com/0xKobold/pi-ollama/issues"
  },
  "homepage": "https://github.com/0xKobold/pi-ollama#readme"
}