{
  "name": "@0xkobold/pi-orchestration",
  "version": "0.3.0",
  "description": "Agnostic subagent orchestration for pi-coding-agent. Supports single, chain, parallel, and fork execution modes with depth limiting and worktree isolation.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "subagent",
    "orchestration",
    "multi-agent",
    "0xkobold"
  ],
  "author": "0xKobold",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "lint": "echo 'No linter configured'",
    "prepublishOnly": "rm -rf dist && tsc"
  },
  "pi": {
    "extensions": ["./dist/index.js"]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.65.0",
    "@sinclair/typebox": ">=0.32.0",
    "@0xkobold/pi-ollama": ">=0.2.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.65.0",
    "@sinclair/typebox": ">=0.32.0",
    "@0xkobold/pi-ollama": ">=0.2.0",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typescript": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xKobold/pi-orchestration.git"
  },
  "bugs": {
    "url": "https://github.com/0xKobold/pi-orchestration/issues"
  },
  "homepage": "https://github.com/0xKobold/pi-orchestration#readme"
}
