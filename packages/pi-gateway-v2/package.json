{
  "name": "@0xkobold/pi-gateway",
  "version": "1.0.0",
  "description": "Hermes-style messaging gateway for pi - multi-platform AI agent gateway",
  "keywords": ["pi-package", "gateway", "messaging", "hermes", "multi-platform", "discord", "telegram"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "demo": "bun run tests/demo.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/ws": "^8.18.0",
    "@types/bun": "^1.2.0",
    "typescript": "^5.8.0",
    "bun-types": "^1.2.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": ["./dist/index.js"],
    "skills": ["./skills"]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xkobold/pi-gateway.git"
  },
  "author": "0xKobold",
  "license": "MIT"
}
