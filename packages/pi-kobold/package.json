{
  "name": "@0xkobold/pi-kobold",
  "version": "0.7.1",
  "description": "Meta-extension for 0xKobold that bundles pi-orchestration, pi-gateway, pi-ollama, pi-learn, pi-persona, and development tools",
  "author": "0xKobold",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "0xkobold",
    "orchestration",
    "gateway",
    "messaging",
    "persona"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "prepublishOnly": "rm -rf dist && tsc"
  },
  "pi": {
    "extensions": [
      "./dist/index.js",
      "./node_modules/@0xkobold/pi-orchestration/dist/index.js",
      "./node_modules/@0xkobold/pi-gateway/dist/index.js",
      "./node_modules/@0xkobold/pi-ollama/dist/index.js",
      "./node_modules/@0xkobold/pi-learn/dist/index.js",
      "./node_modules/@0xkobold/pi-mcp/dist/index.js",
      "./node_modules/@0xkobold/pi-secret-guardian/dist/index.js",
      "./node_modules/@0xkobold/pi-persona/dist/index.js"
    ]
  },
  "peerDependencies": {
    "@0xkobold/pi-learn": "^0.4.0",
    "@0xkobold/pi-mcp": "^0.4.0",
    "@0xkobold/pi-ollama": "0.4.1",
    "@0xkobold/pi-orchestration": "^0.3.0",
    "@0xkobold/pi-persona": "^0.1.0",
    "@0xkobold/pi-secret-guardian": "^0.1.0",
    "@mariozechner/pi-coding-agent": ">=0.65.0",
    "@sinclair/typebox": ">=0.32.0"
  },
  "dependencies": {
    "@0xkobold/pi-gateway": "0.6.0",
    "@0xkobold/pi-learn": "^0.4.0",
    "@0xkobold/pi-mcp": "^0.4.0",
    "@0xkobold/pi-ollama": "0.4.1",
    "@0xkobold/pi-orchestration": "^0.3.0",
    "@0xkobold/pi-persona": "^0.1.0",
    "@0xkobold/pi-secret-guardian": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xKobold/pi-kobold.git"
  },
  "bugs": {
    "url": "https://github.com/0xKobold/pi-kobold/issues"
  },
  "homepage": "https://github.com/0xKobold/pi-kobold#readme"
}
