{
  "name": "0xkobold",
  "version": "0.8.1",
  "description": "Your digital familiar - Koclaw-style gateway, session management, and multi-agent orchestration",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "bin": {
    "0xkobold": "dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist/ .tsbuildinfo",
    "build": "tsc -p tsconfig.build.json",
    "build:clean": "npm run clean && npm run build",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "start": "bun run src/index.ts",
    "cli": "bun run src/cli/index.ts",
    "tui": "bun run src/index.ts",
    "init": "bun run src/cli/index.ts init",
    "test": "bun test",
    "update": "bun run src/cli/index.ts update",
    "update:check": "bun run src/cli/index.ts update check",
    "update:install": "bun run src/cli/index.ts update install",
    "update:framework": "bun run src/cli/index.ts update framework",
    "setup-hooks": "bash scripts/install-hooks.sh",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node scripts/postinstall.js && node scripts/link-pi-extensions.js || echo 'Welcome to 0xKobold! Run: 0xkobold setup'"
  },
  "keywords": [
    "ai",
    "assistant",
    "cli",
    "agent",
    "kobold"
  ],
  "author": "0xKobold Team",
  "license": "MIT",
  "dependencies": {
    "@0xkobold/pi-bridge": "./packages/pi-bridge",
    "@0xkobold/pi-cloudflare-browser": "^0.1.0",
    "@0xkobold/pi-learn": "^0.2.2",
    "@0xkobold/pi-obsidian-bridge": "^0.1.0",
    "@0xkobold/pi-ollama": "^0.2.0",
    "@aliou/pi-processes": "^0.7.0",
    "@mariozechner/pi-agent-core": "0.65.0",
    "@mariozechner/pi-coding-agent": "0.65.0",
    "@mariozechner/pi-tui": "0.65.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "ajv": "^8.18.0",
    "blessed": "^0.1.81",
    "commander": "^14.0.3",
    "discord.js": "^14.26.2",
    "glob": "^13.0.6",
    "json5": "^2.2.3",
    "node-machine-id": "^1.1.12",
    "node-telegram-bot-api": "^0.67.0",
    "nostr-tools": "^2.23.3",
    "ollama": "^0.6.3",
    "pi-extmgr": "^0.1.28",
    "pi-librarian": "^1.3.3",
    "pi-memory-md": "^0.1.22",
    "pi-messenger": "^0.14.1",
    "pi-subagents": "^0.12.2",
    "pi-web-access": "^0.10.6",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "undici": "^7.24.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/bun": "1.3.11",
    "@types/json5": "^2.2.0",
    "@types/node": "^25.5.2",
    "bun-types": "1.3.11",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.7",
  "overrides": {
    "undici": "^7.24.4",
    "file-type": "^21.3.1",
    "fast-xml-parser": "^5.5.6",
    "tough-cookie": "^4.1.4",
    "qs": "^6.14.1",
    "socket.io-parser": "^4.2.6"
  },
  "private": false,
  "files": [
    "dist",
    "scripts/migrate-from-openclaw.sh",
    "scripts/postinstall.js",
    "README.md",
    "LICENSE",
    "package.json",
    "SOUL.md",
    "IDENTITY.md",
    "HEARTBEAT.md",
    "skills/",
    ".agents/skills/"
  ],
  "publishConfig": {
    "access": "public"
  }
}